# 环境变量配置

# Flask 服务配置
FLASK_HOST=0.0.0.0
FLASK_PORT=5012
FLASK_DEBUG=false

# API易配置（推荐，付费 API）
# 在 https://www.apiyi.com 注册后获取 API Key
API_KEY=
APIYI_BASE_URL=https://api.apiyi.com/v1
APIYI_MODEL=dall-e-3
# 可选模型: dall-e-3, dall-e-2, gpt-image-1, sora-image
# 尺寸: 1024x1024, 1792x1024, 1024x1792
APIYI_SIZE=1024x1792
# 质量: standard, hd (hd 更贵但更清晰)
APIYI_QUALITY=standard

# 图片生成配置
# 可选后端: apiyi, pollinations, sd, mj
DEFAULT_IMAGE_BACKEND=apiyi
OUTPUT_DIR=./output

# Stable Diffusion（AUTOMATIC1111）— 选择生成后端 sd（txt2img）时需要
# 启动 WebUI 后填写根地址（不要带路径），例如：
# SD_API_URL=http://127.0.0.1:7860

# Midjourney 配置（可选）
# MJ_API_KEY=your_api_key_here

# 飞书应用凭证（用于在对话框中直接展示图片）
# 在飞书开放平台 https://open.feishu.cn 创建应用后获取
FEISHU_APP_ID=
FEISHU_APP_SECRET=
